# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Google Drive Service Account Credentials
GOOGLE_SERVICE_ACCOUNT_EMAIL="tuo-service-account@tuo-progetto.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ID della cartella principale su Google Drive dove verranno salvati tutti i lotti
GOOGLE_DRIVE_ROOT_FOLDER_ID="1A2b3C4d5E6f7G8h9I0j"
